{
  "defaults": {
    "llm_fail_mode": "closed",
    "unknown_host": "passthrough"
  },
  "gateway": {
    "public_url": "https://gw.example.test",
    "state_dir": "/opt/clawpatrol",
    "wireguard": {
      "subnet_cidr": "10.55.0.0/24"
    }
  },
  "policy": {
    "approvers": {
      "ops": {
        "body": {
          "Channel": "#agent-ops",
          "Credential": "",
          "Timeout": 600,
          "RequireApprovers": 0,
          "Interactive": false,
          "Classifier": "",
          "Message": ""
        },
        "type": "human_approver"
      }
    },
    "credentials": {
      "github": {
        "body": {
          "IdempotencyKey": false
        },
        "endpoint": "github",
        "type": "bearer_token"
      }
    },
    "endpoints": {
      "github": {
        "body": {
          "Hosts": [
            "api.github.com",
            "github.com"
          ]
        },
        "family": "http",
        "type": "https"
      }
    },
    "profiles": {
      "default": {
        "credentials": [
          "github"
        ]
      }
    },
    "rules": {
      "github-reads": {
        "body": {
          "name": "github-reads",
          "family": "http",
          "endpoints": [
            "github"
          ],
          "condition": "http.method in ['GET', 'HEAD']",
          "verdict": "allow"
        }
      },
      "github-writes": {
        "body": {
          "name": "github-writes",
          "family": "http",
          "endpoints": [
            "github"
          ],
          "condition": "http.method in ['POST', 'PATCH', 'DELETE']",
          "approve": [
            {
              "name": "ops"
            }
          ]
        }
      }
    }
  }
}
