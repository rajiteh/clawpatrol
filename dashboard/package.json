{
  "name": "clawpatrol-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "format": "oxfmt src index.html login.html package.json tsconfig.json vite.config.ts",
    "format:check": "oxfmt --check src index.html login.html package.json tsconfig.json vite.config.ts",
    "lint": "oxlint src vite.config.ts",
    "lint:github": "oxlint --format=github src vite.config.ts"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@types/prismjs": "^1.26.6",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-code-editor": "^0.14.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.5.3",
    "vite": "^8.0.11"
  }
}
